{
  "enabledPlugins": {
    "wiki-optimizer@wiki-optimizer-plugins": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"D:/01_personal/04_project/01_wiki-optimizer/plugins/wiki-optimizer/hooks/session-start-wiki-index.js\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Glob|Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"D:/01_personal/04_project/01_wiki-optimizer/plugins/wiki-optimizer/hooks/pre-read-wiki-intercept.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"D:/01_personal/04_project/01_wiki-optimizer/plugins/wiki-optimizer/hooks/post-read-wiki-suggest.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"D:/01_personal/04_project/01_wiki-optimizer/plugins/wiki-optimizer/hooks/stop-suggest-ingest.js\""
          }
        ]
      }
    ]
  }
}
